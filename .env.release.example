# Copie para .env.release na raiz do projeto (NUNCA commitar).

# ── Supabase (manifesto OTA) ─────────────────────────────────────────────────
# Dashboard → Project Settings → API → service_role (secret)
SUPABASE_URL=https://ptedwefjwohitzalovea.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole_a_service_role_key_aqui

# ── GitHub (host do APK) ─────────────────────────────────────────────────────
# Repo no formato: dono/repositorio  (ex: firmisbr/facilite-plus)
GITHUB_REPO=firmisbr/facilite-plus
# Token em: github.com → Settings → Developer settings → Personal access tokens → Fine-grained
# Permissões necessárias: Contents (read & write)
GITHUB_TOKEN=cole_o_token_aqui
